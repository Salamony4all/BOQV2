// Expert FF&E Autofill Suggestions Endpoint
app.get('/api/autofill-suggestions', (req, res) => {
  try {
    const rawQ = req.query.q || '';
    const q = rawQ.toLowerCase().trim();
    let suggestions = [];
    let detectedCategory = null;
    let detectedSubCategory = null;

    if (!q) {
      // Default empty state: suggest main categories
      for (const mainCat of Object.keys(TAXONOMY)) {
        suggestions.push({ type: 'Category', text: mainCat, score: 90 });
      }
      return res.json({ query: q, detected: {}, suggestions: suggestions.slice(0, 10) });
    }
    
    // 1. Check for hits in Taxonomy (Categories & SubCategories)
    for (const [mainCat, subs] of Object.entries(TAXONOMY)) {
      if (mainCat.toLowerCase().includes(q)) {
        suggestions.push({ type: 'Category', text: mainCat, score: 90 });
      }
      for (const [subCat, regex] of Object.entries(subs)) {
        if (regex.test(q) || subCat.toLowerCase().includes(q)) {
          suggestions.push({ type: 'SubCategory', text: subCat, parent: mainCat, score: 100 });
          detectedCategory = mainCat;
          detectedSubCategory = subCat;
        }
      }
    }

    // 2. Check for Role/Rank hits
    for (const level of RANK_MAP) {
      if (level.keywords.test(q)) {
        suggestions.push({ type: 'Rank', text: `Rank ${level.rank} Function`, score: 80 });
      }
    }

    // 3. Check for Material/Feature hits
    for (const [group, features] of Object.entries(FEATURE_TAXONOMY)) {
      for (const [featureName, regex] of Object.entries(features)) {
        if (regex.test(q) || featureName.toLowerCase().includes(q)) {
          suggestions.push({ type: 'Feature', text: featureName, group: group, score: 70 });
        }
      }
    }

    // If a category was detected but the user keeps typing, suggest features contextually
    if (detectedCategory) {
      // Suggest ranks and basic materials
      if (!suggestions.some(s => s.type === 'Rank')) {
         suggestions.push({ type: 'Suggestion', text: 'Specify a Role: e.g. Executive, Staff, Manager', score: 50 });
      }
    }

    // Sort by relevance score
    suggestions.sort((a, b) => b.score - a.score);
    
    // Return to UI
    res.json({ 
      query: q, 
      detected: { category: detectedCategory, subCategory: detectedSubCategory },
      suggestions: suggestions.slice(0, 10) 
    });
  } catch (err) {
    console.error('Autofill error:', err.message);
    res.status(500).json({ error: 'Failed to generate suggestions' });
  }
});

