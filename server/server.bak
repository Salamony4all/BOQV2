// Reset/Cleanup endpoint for app initialization
app.post('/api/reset', async (req, res) => {
  console.log('Resetting application state...');
  // Do not block the HTTP response on cleanup. On local machines this can be slow
  // (recursive deletes / blob deletions) and it causes the frontend to show
  // "Network error occurred" for the initial boot request.
  cleanupService.cleanupAll().catch((e) => {
    console.error('[Reset] Cleanup failed (async):', e?.message || e);
  });
  // Re-create uploads directory immediately to ensure readiness
  const isVercel = process.env.VERCEL === '1';
  const uploadsDir = isVercel ? '/tmp/uploads' : path.join(__dirname, '../uploads');
  const imagesDir = isVercel ? '/tmp/uploads/images' : path.resolve(__dirname, '../uploads/images');
  try {
    // Recursive: true handles missing parents. Using resolve for certainty.
    await fs.mkdir(path.dirname(imagesDir), { recursive: true });
    await fs.mkdir(imagesDir, { recursive: true });
  } catch (e) {
    console.error('Error recreating dirs:', e?.message || e);
  }
  res.json({ success: true, message: 'Environment reset started' });
});



